# Railway Production Environment Variables
# Copy this file to .env on Railway and fill in with actual values

# Database
# Format: postgresql://username:password@host:port/database
# Get from Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:pass@host:5432/bookflow

# JWT Secrets (generate random strings at least 32 characters long)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=generate-a-long-random-string-at-least-32-characters
REFRESH_TOKEN_SECRET=generate-another-long-random-string-at-least-32-characters

# Node Environment
NODE_ENV=production

# Port (Railway will set this automatically, but included for reference)
PORT=3000

# Frontend URL (where your Vercel frontend is deployed)
# Example: https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Groq AI API
# Get free API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
